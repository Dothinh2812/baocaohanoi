# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Zalo / webhook
WEBHOOK_IMAGE_URL=https://your-webhook.example.com/webhook/image
WEBHOOK_TEXT_URL=https://your-webhook.example.com/webhook/text
ZALO_THREAD_DEFAULT=your_default_thread_id

# OneBSS
ONEBSS_USERNAME=your_username
ONEBSS_PASSWORD=your_password
ONEBSS_URL=https://onebss.vnpt.vn
OTP_FILE_PATH=/path/to/otp_logs.txt

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID_MAIN=your_main_chat_id
